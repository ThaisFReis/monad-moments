# ===================================
# Monad Moments MVP — Environment Variables
# ===================================
# Copy this to .env.local and fill in your values

# RainbowKit / WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Pinata (IPFS)
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token
NEXT_PUBLIC_PINATA_GATEWAY=your-gateway.mypinata.cloud

# Deployed Contract Address (fill after deploying MomentNFT.sol)
NEXT_PUBLIC_MOMENT_NFT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS

# Monad Testnet RPC (public)
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
